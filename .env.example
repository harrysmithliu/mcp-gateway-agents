APP_NAME=mcp-gateway-agents
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcp_gateway_agents
REDIS_URL=redis://localhost:6379/0
RESPONSE_CACHE_ENABLED=false
RESPONSE_CACHE_TTL_SECONDS=300
RESPONSE_CACHE_KEY_PREFIX=agent:response
AUTH_MODE=local_jwt
AUTH_JWT_SECRET=replace-with-a-random-local-secret
AUTH_JWT_ISSUER=mcp-gateway-agents
AUTH_JWT_AUDIENCE=mcp-gateway-agents
AUTH_ACCESS_TOKEN_TTL_SECONDS=1800
AUTH_ALLOW_MULTI_IDENTITY=false
RETRIEVAL_ENABLED=true
RETRIEVAL_MIN_SIMILARITY=0.15
EMBEDDING_PROVIDER=local_sentence_transformer
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=384
EMBEDDING_NORMALIZE=true
EMBEDDING_LOCAL_FILES_ONLY=false
EMBEDDING_QUERY_PREFIX=
ANTHROPIC_API_KEY=
LANGCHAIN_MODEL_PROVIDER=anthropic
LANGCHAIN_MODEL_NAME=claude-haiku-4-5
MCP_TRANSPORT_MODE=registry
MCP_SERVER_RUNTIME=preview
UPSTREAM_TRADE_PROJECT=integrations/sources/trade_source/vendor/crypto_trade_plot
UPSTREAM_RISK_PROJECT=integrations/sources/risk_source/vendor/ml_risk_control
